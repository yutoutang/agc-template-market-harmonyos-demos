{
  "app": {
/** todo: 配置手动签名 */
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.5(17)",
        "targetSdkVersion": "5.0.5(17)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "phone",
      "srcPath": "./products/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "business_home",
      "srcPath": "./features/business_home"
    },
    {
      "name": "business_mine",
      "srcPath": "./features/business_mine"
    },
    {
      "name": "business_setting",
      "srcPath": "./features/business_setting"
    },
    {
      "name": "lib_common",
      "srcPath": "./commons/lib_common"
    },
    {
      "name": "lib_widget",
      "srcPath": "./commons/lib_widget"
    },
    {
      "name": "lib_account",
      "srcPath": "./commons/lib_account"
    },
    {
      "name": "lib_loan_api",
      "srcPath": "./commons/lib_loan_api"
    },
    {
      "name": "module_imagepreview",
      "srcPath": "./components/module_imagepreview"
    },
    {
      "name": "module_feedback",
      "srcPath": "./components/module_feedback"
    },
    {
      "name": "module_card_verification",
      "srcPath": "./components/module_card_verification"
    },
    {
      "name": "module_ui_base",
      "srcPath": "./components/module_ui_base"
    },
    {
      "name": "module_face_verification",
      "srcPath": "./components/module_face_verification"
    },
    {
      "name": "module_customer_service",
      "srcPath": "./components/module_customer_service"
    },
    {
      "name": "module_loan_form",
      "srcPath": "./components/module_loan_form"
    },
    {
      "name": "aggregated_payment",
      "srcPath": "./components/aggregated_payment"
    }
  ]
