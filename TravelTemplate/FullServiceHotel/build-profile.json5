{
  "app": {
/** todo: 手动签名 */
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "5.0.4(16)",
        "compatibleSdkVersion": "5.0.4(16)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./products/entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "commonlib",
      "srcPath": "./commons/commonlib"
    },
    {
      "name": "componentlib",
      "srcPath": "./commons/componentlib"
    },
    {
      "name": "commonservice",
      "srcPath": "./features/commonservice",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "banquet",
      "srcPath": "./features/banquet"
    },
    {
      "name": "catering",
      "srcPath": "./features/catering",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "hotel",
      "srcPath": "./features/hotel",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "network",
      "srcPath": "./commons/network"
    },
    {
      "name": "module_store_comments",
      "srcPath": "./components/module_store_comments"
    },
    {
      "name": "module_ui_base",
      "srcPath": "./components/module_ui_base"
    },
    {
      "name": "module_date_selector",
      "srcPath": "./components/module_date_selector"
    },
    {
      "name": "module_call_dialog",
      "srcPath": "./components/module_call_dialog"
    },
    {
      "name": "module_login",
      "srcPath": "./components/module_login"
    },
    {
      "name": "settings",
      "srcPath": "./features/settings"
    },
    {
      "name": "module_privacy_agreement",
      "srcPath": "./components/module_privacy_agreement"
    }
  ]
}