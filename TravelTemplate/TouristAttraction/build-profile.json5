{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "5.0.3(15)",
        "compatibleSdkVersion": "5.0.3(15)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "phone",
      "srcPath": "./products/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "guide",
      "srcPath": "./features/guide"
    },
    {
      "name": "mine",
      "srcPath": "./features/mine"
    },
    {
      "name": "types",
      "srcPath": "./commons/types",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "uicomponents",
      "srcPath": "./commons/uicomponents",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "order",
      "srcPath": "./features/order"
    },
    {
      "name": "network",
      "srcPath": "./commons/network",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "ticket",
      "srcPath": "./features/ticket"
    },
    {
      "name": "common",
      "srcPath": "./commons/common",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "home",
      "srcPath": "./features/home"
    },
    {
      "name": "attraction_live",
      "srcPath": "./components/attraction_live"
    },
    {
      "name": "service_hotline",
      "srcPath": "./components/service_hotline"
    },
    {
      "name": "catering_accommodation",
      "srcPath": "./components/catering_accommodation"
    },
    {
      "name": "module_base",
      "srcPath": "./components/module_base"
    },
    {
      "name": "tourist_management",
      "srcPath": "./components/tourist_management"
    },
    {
      "name": "attraction_announcement",
      "srcPath": "./components/attraction_announcement"
    },
    {
      "name": "attraction_guide",
      "srcPath": "./components/attraction_guide"
    },
    {
      "name": "attraction_note",
      "srcPath": "./components/attraction_note"
    }
  ]
}