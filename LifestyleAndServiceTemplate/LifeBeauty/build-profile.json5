{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.3(15)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./products/entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "foundation",
      "srcPath": "./commons/foundation"
    },
    {
      "name": "profile_edit",
      "srcPath": "./components/profile_edit"
    },
    {
      "name": "reservation_card",
      "srcPath": "./components/reservation_card"
    },
    {
      "name": "reservation_form",
      "srcPath": "./components/reservation_form"
    },
    {
      "name": "home",
      "srcPath": "./features/home"
    },
    {
      "name": "mine",
      "srcPath": "./features/mine"
    }
  ]
}