{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "5.0.5(17)",
        "compatibleSdkVersion": "5.0.3(15)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./products/entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "common",
      "srcPath": "./commons/common"
    },
    {
      "name": "person",
      "srcPath": "./features/person"
    },
    {
      "name": "aggregated_login",
      "srcPath": "./components/aggregated_login"
    },
    {
      "name": "oh_router",
      "srcPath": "./commons/oh_router"
    },
    {
      "name": "city_select",
      "srcPath": "./components/city_select"
    },
    {
      "name": "check_app_update",
      "srcPath": "./components/check_app_update"
    },
    {
      "name": "feedback",
      "srcPath": "./components/feedback"
    },
    {
      "name": "collect_personal_info",
      "srcPath": "./components/collect_personal_info"
    },
    {
      "name": "address_management",
      "srcPath": "./components/address_management"
    },
    {
      "name": "homepage",
      "srcPath": "./features/homepage"
    },
    {
      "name": "module_filter_list",
      "srcPath": "./components/module_filter_list"
    },
    {
      "name": "category_list",
      "srcPath": "./components/category_list"
    },
    {
      "name": "module_time_line",
      "srcPath": "./components/module_time_line"
    },
    {
      "name": "valuation_information",
      "srcPath": "./components/valuation_information"
    },
    {
      "name": "link_category",
      "srcPath": "./components/link_category"
    },
    {
      "name": "module_time_select",
      "srcPath": "./components/module_time_select"
    },
    {
      "name": "recyclingservice_process_step",
      "srcPath": "./components/recyclingservice_process_step"
    },
    {
      "name": "calendar_select",
      "srcPath": "./components/calendar_select"
    }
  ]
}