{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.5(17)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "phone",
      "srcPath": "./products/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "lib_foundation",
      "srcPath": "./commons/lib_foundation"
    },
    {
      "name": "module_voice_broadcast",
      "srcPath": "./components/module_voice_broadcast"
    },
    {
      "name": "module_theme",
      "srcPath": "./components/module_theme"
    },
    {
      "name": "module_city_manage",
      "srcPath": "./components/module_city_manage"
    },
    {
      "name": "module_weather_core",
      "srcPath": "./components/module_weather_core"
    },
    {
      "name": "business_home",
      "srcPath": "./features/business_home"
    },
    {
      "name": "business_mine",
      "srcPath": "./features/business_mine"
    },
    {
      "name": "module_login",
      "srcPath": "./components/module_login"
    }
  ]
}