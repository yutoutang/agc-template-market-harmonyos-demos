{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "5.0.5(17)",
        "compatibleSdkVersion": "5.0.3(15)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./products/entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "common",
      "srcPath": "./commons/common"
    },
    {
      "name": "person",
      "srcPath": "./features/person"
    },
    {
      "name": "oh_router",
      "srcPath": "./commons/oh_router"
    },
    {
      "name": "check_app_update",
      "srcPath": "./components/check_app_update"
    },
    {
      "name": "feedback",
      "srcPath": "./components/feedback"
    },
    {
      "name": "aggregated_login",
      "srcPath": "./components/aggregated_login"
    },
    {
      "name": "collect_personal_info",
      "srcPath": "./components/collect_personal_info"
    },
    {
      "name": "text_reader",
      "srcPath": "./components/text_reader"
    },
    {
      "name": "home",
      "srcPath": "./features/home"
    },
    {
      "name": "choose_language",
      "srcPath": "./components/choose_language"
    },
    {
      "name": "voice_input",
      "srcPath": "./components/voice_input"
    },
    {
      "name": "vip_center",
      "srcPath": "./components/vip_center"
    },
    {
      "name": "base_apis",
      "srcPath": "./components/base_apis"
    },
    {
      "name": "aggregated_payment",
      "srcPath": "./components/aggregated_payment"
    },
    {
      "name": "baidu_translate",
      "srcPath": "./sdk/baidu_translate"
    }
  ]
}