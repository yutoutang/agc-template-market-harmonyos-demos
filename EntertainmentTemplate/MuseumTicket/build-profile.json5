      "srcPath": "./features/order",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "explain",
      "srcPath": "./features/explain",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "module_card_swiper",
      "srcPath": "./components/module_card_swiper"
    },
    {
