{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.3(15)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "phone",
      "srcPath": "./product/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "common_lib",
      "srcPath": "./commons/common_lib"
    },
    {
      "name": "component_lib",
      "srcPath": "./commons/component_lib"
    },
    {
      "name": "network",
      "srcPath": "./commons/network"
    },
    {
      "name": "agency",
      "srcPath": "./scenes/agency",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "schedule",
      "srcPath": "./scenes/schedule",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "account",
      "srcPath": "./scenes/account",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "clock_in",
      "srcPath": "./components/clock_in"
    },
    {
      "name": "protractor",
      "srcPath": "./components/protractor"
    },
    {
      "name": "area_calculate",
      "srcPath": "./components/area_calculate"
    },
    {
      "name": "ruler",
      "srcPath": "./components/ruler"
    }
  ]
}