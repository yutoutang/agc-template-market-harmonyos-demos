{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "5.0.5(17)",
        "compatibleSdkVersion": "5.0.3(15)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./products/entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "common",
      "srcPath": "./commons/common"
    },
    {
      "name": "person",
      "srcPath": "./features/person"
    },
    {
      "name": "aggregated_login",
      "srcPath": "./components/aggregated_login"
    },
    {
      "name": "message_manager",
      "srcPath": "./components/message_manager"
    },
    {
      "name": "oh_router",
      "srcPath": "./commons/oh_router"
    },
    {
      "name": "city_select",
      "srcPath": "./components/city_select"
    },
    {
      "name": "check_app_update",
      "srcPath": "./components/check_app_update"
    },
    {
      "name": "collect_personal_info",
      "srcPath": "./components/collect_personal_info"
    },
    {
      "name": "search_box",
      "srcPath": "./components/search_box"
    },
    {
      "name": "aggregated_share",
      "srcPath": "./components/aggregated_share"
    },
    {
      "name": "position",
      "srcPath": "./features/position"
    },
    {
      "name": "message",
      "srcPath": "./features/message"
    },
    {
      "name": "file_management",
      "srcPath": "./components/file_management"
    },
    {
      "name": "link_category",
      "srcPath": "./components/link_category"
    },
    {
      "name": "resume",
      "srcPath": "./components/resume"
    },
    {
      "name": "job_intention",
      "srcPath": "./components/job_intention"
    },
    {
      "name": "chat_base",
      "srcPath": "./components/chat_base"
    },
    {
      "name": "chat_input",
      "srcPath": "./components/chat_input"
    },
    {
      "name": "chat_window",
      "srcPath": "./components/chat_window"
    },
    {
      "name": "instant_messaging",
      "srcPath": "./sdk/instant_messaging"
    },
    {
      "name": "chat_location",
      "srcPath": "./components/chat_location"
    },
    {
      "name": "chat_history_search",
      "srcPath": "./components/chat_history_search"
    },
    {
      "name": "chat_history_collection",
      "srcPath": "./components/chat_history_collection"
    }
  ]
}