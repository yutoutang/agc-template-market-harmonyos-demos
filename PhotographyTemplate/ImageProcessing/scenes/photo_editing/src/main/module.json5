{
  "module": {
    "name": "photo_editing",
    "routerMap": "$profile:router_map",
    "type": "har",
    "deviceTypes": [
      "default"
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.CAMERA",
        "reason": "$string:camera_request",
        "usedScene": {
          "when": "inuse"
        }
      }
    ]
  }
}
