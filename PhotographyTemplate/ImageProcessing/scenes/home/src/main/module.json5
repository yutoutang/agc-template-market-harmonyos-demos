{
  "module": {
    "name": "home",
    "type": "har",
    "deviceTypes": [
      "default",
      "tablet",
      "2in1"
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.CAMERA",
        "reason": "$string:camera_request",
        "usedScene": {
          "when": "inuse"
        }
      },
    ]
  }
}
