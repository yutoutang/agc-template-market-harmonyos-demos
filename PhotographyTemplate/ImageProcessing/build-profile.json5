{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "5.1.0(18)",
        "targetSdkVersion": "6.0.1(21)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "phone",
      "srcPath": "./product/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "commonlib",
      "srcPath": "./commons/commonlib"
    },
    {
      "name": "mine",
      "srcPath": "./scenes/mine"
    },
    {
      "name": "home",
      "srcPath": "./scenes/home"
    },
    {
      "name": "login_info",
      "srcPath": "./components/login_info"
    },
    {
      "name": "feed_back",
      "srcPath": "./components/feed_back"
    },
    {
      "name": "personal",
      "srcPath": "./scenes/personal"
    },
    {
      "name": "membership",
      "srcPath": "./components/membership"
    },
    {
      "name": "camera_lut",
      "srcPath": "./commons/camera_lut",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "camera",
      "srcPath": "./scenes/camera"
    },
    {
      "name": "photo_editing",
      "srcPath": "./scenes/photo_editing"
    }
  ]
}