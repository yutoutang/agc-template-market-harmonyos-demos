{
  "module": {
    "name": "ar_measure",
    "type": "har",
    "routerMap": '$profile:router_map',
    "deviceTypes": [
      "default"
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.CAMERA",
        "reason": "$string:page_show",
        "usedScene": {
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.GYROSCOPE",
        "reason": "$string:page_show",
        "usedScene": {
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.ACCELEROMETER",
        "reason": "$string:page_show",
        "usedScene": {
          "when": "always"
        }
      }
    ]
  }
}
