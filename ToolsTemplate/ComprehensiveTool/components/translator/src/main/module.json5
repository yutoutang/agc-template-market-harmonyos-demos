{
  "module": {
    "name": "translator",
    "type": "har",
    "routerMap": '$profile:router_map',
    "deviceTypes": [
      "default"
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET",
      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:apply_microphone_reason",
        "usedScene": {
          "when": "inuse"
        }
      }
    ]
  }
}
