{
  "module": {
    "name": "simple_recorder",
    "type": "har",
    "routerMap":"$profile:route_map" ,
    "deviceTypes": [
      "phone"
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:apply_microphone_reason",
        "usedScene": {
          "when": "inuse"
        }
      }
    ]
  }
}
