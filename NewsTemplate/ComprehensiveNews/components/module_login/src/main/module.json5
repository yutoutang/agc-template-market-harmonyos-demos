{
  "module": {
    "name": "module_login",
    "type": "har",
    "routerMap": "$profile:route_map",
    "deviceTypes": [
      "phone",
      "tablet",
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO"
      },
      {
        "name": "ohos.permission.PRIVACY_WINDOW"
      }
    ]
  }
}