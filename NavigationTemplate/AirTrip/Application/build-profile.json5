{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "6.0.0(20)",
        "compatibleSdkVersion": "6.0.0(20)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "phone",
      "srcPath": "./products/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "common",
      "srcPath": "./commons/common"
    },
    {
      "name": "home",
      "srcPath": "./features/home"
    },
    {
      "name": "itinerary",
      "srcPath": "./features/itinerary"
    },
    {
      "name": "mine",
      "srcPath": "./features/mine"
    },
    {
      "name": "flight",
      "srcPath": "./features/flight"
    },
    {
      "name": "components",
      "srcPath": "./commons/components"
    }
  ]
}