{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.3(15)",
        "targetSdkVersion": "5.0.3(15)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "phone",
      "srcPath": "./products/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "home",
      "srcPath": "./scenes/home"
    },
    {
      "name": "stores",
      "srcPath": "./scenes/stores"
    },
    {
      "name": "mine",
      "srcPath": "./scenes/mine"
    },
    {
      "name": "uicomponents",
      "srcPath": "./commons/uicomponents"
    },
    {
      "name": "utils",
      "srcPath": "./commons/utils"
    },
    {
      "name": "activities",
      "srcPath": "./scenes/activities"
    },
    {
      "name": "double_layer_tabs",
      "srcPath": "./components/double_layer_tabs",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}