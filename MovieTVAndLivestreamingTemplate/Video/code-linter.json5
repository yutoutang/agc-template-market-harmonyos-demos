{
  "files": [
    "**/*.ets"
  ],
  "ignore": [
    "**/src/ohosTest/**/*",
    "**/src/test/**/*",
    "**/src/mock/**/*",
    "**/node_modules/**/*",
    "**/oh_modules/**/*",
    "**/build/**/*",
    "**/.preview/**/*"
  ],
  "ruleSet": [
    "plugin:@performance/recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:@hw-stylistic/recommended",
    "plugin:@security/all"
  ],
  "rules": {
    // 尽可能的使用单引号
    "@typescript-eslint/quotes": [
      "error",
      "single"
    ],
    // 要求使用===和!==
    "eqeqeq": "error",
    // 不使用的代码段建议直接删除
    "@security/no-commented-code": "error",
    // 代码中禁止包含未使用的表达式
    "@typescript-eslint/no-unused-expressions": "error",
    // 默认类名为大驼峰的命名风格，函数名为小驼峰的命名风格
    "@typescript-eslint/naming-convention": "error",
    // 强制字符串使用单引号。该规则仅检查.ets文件类型。
    "@hw-stylistic/quotes": "error",
    // 强制代码行最大长度为120个字符。该规则仅检查.ets文件类型。
    "@hw-stylistic/max-len": "error",
    // 强制运算符位于代码行末。该规则仅检查.ets文件类型。
    "@hw-stylistic/operator-linebreak": "error",
    // 建议在ForEach参数中设置keyGenerator。
    "@performance/foreach-args-check": "error",
    // 使用Foreach组件时，不建议在keyGenerator中使用index作为返回值或者返回值的一部分，可能会导致性能问题。
    "@performance/foreach-index-check": "error",
    // 不允许使用“Array”构造函数。
    "@typescript-eslint/no-array-constructor": "error",
    // 该规则检测使用lottie加载的动画是否都正确销毁
    "@performance/lottie-animation-destroy-check": "error",
    // 启动页图标分辨率建议不超过256 * 256。
    "@performance/start-window-icon-check": "error",
    // 该规则禁止使用循环依赖
    "@security/no-cycle": "error",
    // 定义数组类型时，建议使用相同的样式。比如都使用T[]或者都使用Array<T>。
    "@typescript-eslint/array-type": "error",
    // 不允许对不是“Thenable”对象的值使用await关键字（“Thenable”表示某个对象拥有“then”方法，比如Promise）。
    "@typescript-eslint/await-thenable": "error",
    // 不允许使用空函数。
    "@typescript-eslint/no-empty-function": "error",
    // 不允许声明空接口
    "@typescript-eslint/no-empty-interface": "error",
    // 不允许使用“any”类型。
    "@typescript-eslint/no-explicit-any": "error",
    // 禁止将布尔值和布尔字面量直接进行比较。
    "@typescript-eslint/no-unnecessary-boolean-literal-compare": "error",
    // 强制使用点表示法
    "@typescript-eslint/dot-notation": "error",
  }
}