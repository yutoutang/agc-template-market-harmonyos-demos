{
  "app": {
/**todo: 配置手动签名 */
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.4(16)",
        "targetSdkVersion": "5.0.4(16)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./products/entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "shopping",
      "srcPath": "./features/shopping"
    },
    {
      "name": "order",
      "srcPath": "./features/order"
    },
    {
      "name": "module_product_detail",
      "srcPath": "./components/module_product_detail"
    },
    {
      "name": "lib_foundation",
      "srcPath": "./commons/lib_foundation"
    },
    {
      "name": "module_address_manage",
      "srcPath": "./components/module_address_manage"
    },
    {
      "name": "module_product_waterflow",
      "srcPath": "./components/module_product_waterflow"
    },
    {
      "name": "module_shopping_cart",
      "srcPath": "./components/module_shopping_cart"
    },
    {
      "name": "module_login",
      "srcPath": "./components/module_login"
    },
    {
      "name": "module_coupons",
      "srcPath": "./components/module_coupons"
    },
    {
      "name": "module_product_share",
      "srcPath": "./components/module_product_share"
    },
    {
      "name": "module_product_search",
      "srcPath": "./components/module_product_search"
    },
    {
      "name": "module_privacy_agreement",
      "srcPath": "./components/module_privacy_agreement"
    },
    {
      "name": "module_ui_base",
      "srcPath": "./components/module_ui_base"
    },
    {
      "name": "setting",
      "srcPath": "./features/setting"
    },
    {
      "name": "lib_network",
      "srcPath": "./commons/lib_network"
    },
    {
      "name": "lib_widget",
      "srcPath": "./commons/lib_widget"
    },
    {
      "name": "module_product_review",
      "srcPath": "./components/module_product_review"
    },
    {
      "name": "module_product_category",
      "srcPath": "./components/module_product_category"
    }
  ]
}